---
export const prerender = false;
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Feelings from '../components/Feelings.astro';
import About from '../components/About.astro';
import HowIWork from '../components/HowIWork.astro';
import Sessions from '../components/Sessions.astro';
import Mentoring from '../components/Mentoring.astro';
import Testimonial from '../components/Testimonial.astro';
import Faq from '../components/Faq.astro';
import FinalCta from '../components/FinalCta.astro';
import Footer from '../components/Footer.astro';
import BookingModal from '../components/BookingModal.astro';
import { social } from '../data/site';
import { getOfferings, activeByArm, priceLabel } from '../lib/offerings';

// Server-rendered so pricing reflects admin edits live; edge-cached so it stays fast and
// Firestore is read at most ~once per window. Edits propagate within ~30s.
Astro.response.headers.set('Cache-Control', 'public, max-age=0, s-maxage=30, stale-while-revalidate=86400');

const offerings = await getOfferings();
const counselling = activeByArm(offerings, 'counselling');
const amounts = offerings.filter((o) => o.active && o.amountPaise > 0).map((o) => o.amountPaise);
const priceRange = amounts.length
  ? `${priceLabel(Math.min(...amounts))}-${priceLabel(Math.max(...amounts))}`
  : '₹599-₹3,399';

const schema = {
  '@context': 'https://schema.org',
  '@type': 'ProfessionalService',
  name: 'Disha Jain · Counselling & Psychology Mentoring',
  url: 'https://jaindisha.in',
  image: 'https://jaindisha.in/disha.jpeg',
  description:
    'Warm, one-to-one online counselling and psychology mentoring with Disha Jain, a PsyD trainee and counsellor with 7+ years of experience.',
  areaServed: 'IN',
  priceRange,
  founder: {
    '@type': 'Person',
    name: 'Disha Jain',
    jobTitle: 'Counsellor & PsyD trainee',
    sameAs: [social.linkedin],
  },
  sameAs: [social.linkedin],
};
---

<Base>
  <script type="application/ld+json" is:inline set:html={JSON.stringify(schema)} />
  <Nav />
  <Hero />
  <Feelings />
  <About />
  <HowIWork />
  <Sessions sessions={counselling} />
  <Mentoring />
  <Testimonial />
  <Faq />
  <FinalCta />
  <Footer />
  <BookingModal />
</Base>
