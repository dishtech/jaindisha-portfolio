---
import Base from '../../layouts/Base.astro';
---

<Base title="Admin sign in · Disha Jain" description="Admin sign in.">
  <main class="wrap login">
    <div class="login-card">
      <p class="kicker">Admin</p>
      <h1 class="serif">Sign in</h1>
      <p class="login-sub">Use the Google account that has admin access.</p>
      <button id="google-signin" class="g-btn" type="button">
        <svg class="g-icon" viewBox="0 0 18 18" aria-hidden="true" width="18" height="18">
          <path fill="#4285F4" d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84a4.14 4.14 0 0 1-1.8 2.72v2.26h2.92c1.7-1.57 2.68-3.88 2.68-6.62z"/>
          <path fill="#34A853" d="M9 18c2.43 0 4.47-.8 5.96-2.18l-2.92-2.26c-.8.54-1.84.86-3.04.86-2.34 0-4.32-1.58-5.02-3.7H.96v2.34A9 9 0 0 0 9 18z"/>
          <path fill="#FBBC05" d="M3.98 10.72a5.4 5.4 0 0 1 0-3.44V4.94H.96a9 9 0 0 0 0 8.12l3.02-2.34z"/>
          <path fill="#EA4335" d="M9 3.58c1.32 0 2.5.46 3.44 1.35l2.58-2.59C13.47.9 11.43 0 9 0A9 9 0 0 0 .96 4.94l3.02 2.34C4.68 5.16 6.66 3.58 9 3.58z"/>
        </svg>
        <span>Sign in with Google</span>
      </button>
      <p class="err" hidden></p>
      <p class="login-note">Access is restricted to approved admin accounts.</p>
    </div>
  </main>
</Base>

<script>
  import { GoogleAuthProvider, signInWithPopup } from 'firebase/auth';
  import { auth } from '../../lib/firebaseClient';

  const btn = document.getElementById('google-signin') as HTMLButtonElement | null;
  const err = document.querySelector('.err') as HTMLElement | null;
  const label = btn?.querySelector('span') as HTMLElement | null;

  const provider = new GoogleAuthProvider();
  provider.setCustomParameters({ prompt: 'select_account' }); // always let them pick the account

  function setBusy(busy: boolean, text: string) {
    if (!btn) return;
    btn.disabled = busy;
    btn.classList.toggle('loading', busy);
    if (label) label.textContent = text;
  }

  btn?.addEventListener('click', async () => {
    if (!err) return;
    err.hidden = true;
    setBusy(true, 'Signing in…');
    try {
      const cred = await signInWithPopup(auth, provider);
      const idToken = await cred.user.getIdToken();
      const r = await fetch('/api/session-login', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ idToken }),
      });
      if (r.ok) {
        // Success: stay disabled while the redirect loads so the button never looks re-clickable.
        setBusy(true, 'Taking you in…');
        window.location.assign('/admin');
        return;
      }
      // Authenticated with Google, but this email isn't on the admin allowlist — let them retry.
      err.textContent = "This Google account doesn't have admin access.";
      err.hidden = false;
      setBusy(false, 'Sign in with Google');
    } catch (e: any) {
      const code = e?.code || '';
      if (code === 'auth/popup-closed-by-user' || code === 'auth/cancelled-popup-request') {
        err.textContent = 'Sign-in was cancelled.';
      } else {
        err.textContent = 'Sign in failed. Please try again.';
      }
      err.hidden = false;
      setBusy(false, 'Sign in with Google'); // re-enable only on failure
    }
  });
</script>

<style>
  .login { max-width: 460px; padding: clamp(60px, 10vh, 120px) 32px; }
  .login-card {
    background: var(--cream2);
    border: 1px solid var(--line);
    border-radius: 22px;
    padding: clamp(32px, 5vw, 44px);
    box-shadow: 0 40px 80px -44px rgba(58, 46, 35, 0.4);
  }
  .login-card h1 { font-size: clamp(30px, 4vw, 42px); margin: 8px 0 6px; }
  .login-sub { font-size: 15px; color: var(--body); margin-bottom: 26px; }
  .g-btn {
    width: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    font-family: var(--sans);
    font-size: 15px;
    font-weight: 600;
    color: var(--ink);
    background: #fff;
    border: 1.5px solid var(--line);
    border-radius: 100px;
    padding: 13px 20px;
    cursor: pointer;
    transition: border-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .g-btn:hover:not(:disabled) { border-color: var(--clay); box-shadow: 0 14px 30px -18px rgba(168, 93, 66, 0.55); transform: translateY(-1px); }
  .g-btn:disabled { opacity: 0.6; cursor: default; }
  .g-icon { flex: 0 0 auto; }
  .err { color: var(--clay-dk); font-size: 14px; margin: 16px 0 0; font-weight: 600; }
  .login-note { font-size: 12.5px; color: #a08e76; margin: 18px 0 0; }
</style>
