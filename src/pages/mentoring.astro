---
import Base from '../layouts/Base.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { mentoring, mentoringAbout, social } from '../data/site';

const title = 'Mentoring for aspiring psychologists — Disha Jain';
const description =
  'Mentoring for psychology students and early-career psychologists with Disha Jain (AIR 1, NIEPVD): entrance prep, mock interviews, and career guidance from someone who has walked the path.';
---

<Base title={title} description={description}>
  <Nav />

  <main>
    <!-- intro / credibility -->
    <section id="mentoring-top">
      <div class="wrap intro-grid">
        <div class="rv">
          <p class="kicker sage">For aspiring psychologists</p>
          <h1>Mentoring for the road<br />into <span class="em">psychology.</span></h1>
          <p class="lead">{mentoringAbout.intro}</p>
          <div class="quals">
            {mentoringAbout.quals.map((q) => <span>{q}</span>)}
          </div>
        </div>

        <aside class="cred-card rv">
          <span class="air-num serif">{mentoringAbout.air.num}</span>
          <span class="air-label">{mentoringAbout.air.label}</span>
          <p class="air-note">{mentoringAbout.airNote}</p>
        </aside>
      </div>
    </section>

    <!-- packages -->
    <section id="offers">
      <div class="wrap">
        <div class="center rv">
          <p class="kicker stamp">Ways to work together</p>
          <h2 class="h-sec">What I offer.</h2>
          <p class="lead center-lead">Pick what fits where you are — a single session, or a focused series.</p>
        </div>

        <div class="offers-grid">
          {
            mentoring.map((o) => (
              <div class="ocard rv">
                {o.tag && <span class="otag">{o.tag}</span>}
                <h3 class="serif">{o.name}</h3>
                <p class="odesc">{o.desc}</p>
                <div class="ometa">
                  <span class="oprice">{o.price}</span>
                  <span class="odur">{o.duration}</span>
                </div>
                {/* M3: replace interim Topmate link with the in-page booking flow */}
                <a class="pill solid obook" href={social.topmate} target="_blank" rel="noopener noreferrer">
                  Book <span class="ar">&rarr;</span>
                </a>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- closing -->
    <section>
      <div class="wrap">
        <div class="m-final rv">
          <h2 class="serif">Not sure where to start?</h2>
          <p>Begin with a short Introductory Guidance call — we'll figure out the right next step together.</p>
          <a class="pill solid" href={social.topmate} target="_blank" rel="noopener noreferrer">
            Start with an intro call <span class="ar">&rarr;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Base>

<style>
  .sage {
    color: var(--sage-dk);
  }

  /* ---- intro ---- */
  #mentoring-top {
    padding-top: clamp(40px, 6vw, 72px);
  }
  .intro-grid {
    display: grid;
    grid-template-columns: 1.25fr 0.75fr;
    gap: clamp(34px, 5vw, 72px);
    align-items: center;
  }
  .intro-grid h1 {
    font-size: clamp(38px, 5vw, 62px);
    margin: 16px 0 18px;
  }
  .quals {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }
  .quals span {
    font-size: 13px;
    font-weight: 600;
    color: var(--clay);
    background: var(--cream2);
    border: 1px solid var(--line);
    padding: 8px 15px;
    border-radius: 100px;
  }
  .cred-card {
    background: linear-gradient(165deg, #4a3a2c, var(--dark));
    border-radius: 26px;
    padding: clamp(30px, 4vw, 42px);
    color: #e9ddcd;
    box-shadow: 0 40px 80px -40px rgba(58, 46, 35, 0.7);
    display: flex;
    flex-direction: column;
  }
  .cred-card .air-num {
    font-size: clamp(56px, 7vw, 84px);
    font-weight: 600;
    color: var(--sand);
    line-height: 0.9;
  }
  .cred-card .air-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #d8c6ad;
    font-weight: 700;
    margin-top: 12px;
  }
  .cred-card .air-note {
    font-family: var(--display);
    font-style: italic;
    font-size: 16px;
    color: #ece0d0;
    margin-top: 20px;
    line-height: 1.4;
  }

  /* ---- offers ---- */
  .center-lead {
    margin: 14px auto 0;
  }
  .offers-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 50px;
  }
  .ocard {
    position: relative;
    display: flex;
    flex-direction: column;
    background: var(--cream2);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 28px 26px;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s;
  }
  .ocard:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -34px rgba(58, 46, 35, 0.45);
  }
  .otag {
    align-self: flex-start;
    font-size: 10.5px;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--dark);
    background: var(--sand);
    padding: 5px 12px;
    border-radius: 100px;
    margin-bottom: 12px;
  }
  .ocard h3 {
    font-size: 21px;
  }
  .odesc {
    font-size: 14px;
    margin: 10px 0 20px;
    flex: 1;
  }
  .ometa {
    display: flex;
    align-items: baseline;
    gap: 10px;
    margin-bottom: 20px;
  }
  .oprice {
    font-family: var(--display);
    font-size: 30px;
    font-weight: 600;
    color: var(--clay);
    line-height: 1;
  }
  .odur {
    font-size: 12.5px;
    color: #a08e76;
  }
  .obook {
    justify-content: center;
  }

  /* ---- closing ---- */
  .m-final {
    position: relative;
    overflow: hidden;
    background: linear-gradient(150deg, var(--sage), var(--sage-dk));
    border-radius: 36px;
    text-align: center;
    color: #fff;
    padding: clamp(54px, 7vw, 90px) 28px;
  }
  .m-final h2 {
    color: #fff;
    font-size: clamp(30px, 4vw, 50px);
    margin-bottom: 14px;
  }
  .m-final p {
    color: #e6efe4;
    max-width: 46ch;
    margin: 0 auto 30px;
    font-size: 16px;
  }
  .m-final .pill.solid {
    background: var(--cream2);
    color: var(--sage-dk);
    box-shadow: 0 16px 36px -14px rgba(0, 0, 0, 0.35);
  }

  @media (max-width: 880px) {
    .intro-grid {
      grid-template-columns: 1fr;
    }
    .offers-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
