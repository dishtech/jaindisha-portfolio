---
import { feelings } from '../data/site';
---

<section id="who">
  <div class="wrap">
    <div class="center rv">
      <p class="kicker stamp">If you're here, something brought you</p>
      <h2 class="h-sec">You don't have to carry it<br />all by <span class="em">yourself.</span></h2>
    </div>
    <div class="feelings">
      {
        feelings.map((f) => (
          <div class="feel rv">
            <span class="idx">{f.idx}</span>
            <h3>{f.title}</h3>
            <p>{f.body}</p>
          </div>
        ))
      }
    </div>
  </div>
</section>

<style>
  .feelings {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
    margin-top: 46px;
  }
  .feel {
    position: relative;
    background: var(--cream2);
    border: 1px solid var(--line);
    border-radius: 20px;
    padding: 34px 28px 30px;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s;
  }
  .feel:hover {
    transform: translateY(-6px);
    box-shadow: 0 30px 60px -34px rgba(58, 46, 35, 0.45);
  }
  .feel .idx {
    font-family: var(--display);
    font-size: 15px;
    color: var(--sand);
    font-weight: 600;
  }
  .feel h3 {
    font-size: 25px;
    margin: 14px 0 8px;
  }
  .feel p {
    font-size: 14.5px;
  }

  @media (max-width: 880px) {
    .feelings {
      grid-template-columns: 1fr;
    }
  }
</style>
