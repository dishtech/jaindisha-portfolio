# Secrets + config for jaindisha. Copy to .env (gitignored) and fill in.
# NEVER commit real values. The same values also go into Netlify env vars.

# === Firebase Admin SDK (server only — SECRET, never PUBLIC_) ===
# Use EITHER Option A or Option B.
# Option A (recommended): base64 of the whole service-account JSON, one line:
#   base64 -i /path/to/jaindisha-firebase-adminsdk-XXXX.json | tr -d '\n'
FIREBASE_SERVICE_ACCOUNT_B64=
# Option B: copy these three fields out of the JSON instead:
# FIREBASE_PROJECT_ID=jaindisha
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@jaindisha.iam.gserviceaccount.com
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# === Cal.com (M3 — scheduling) ===
# Cal.com > Settings > Developer > API keys. Also set calEventTypeId per session in src/data/sessions.ts.
CALCOM_API_KEY=
# Shared secret you set when registering the Cal.com webhook (for /api/cal-webhook):
CAL_WEBHOOK_SECRET=

# === Razorpay (M4 — payments) ===
# Dashboard > Settings > API Keys. Use rzp_test_* keys to start (no KYC); swap to rzp_live_* after KYC.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
# Optional: Dashboard > Webhooks secret (for /api/razorpay-webhook):
RAZORPAY_WEBHOOK_SECRET=

# === Firebase Web config (PUBLIC, browser-safe; M5 admin login) ===
# Firebase Console > Project Settings > Your apps > Web app > SDK config. Safe to expose to the browser.
PUBLIC_FIREBASE_API_KEY=
PUBLIC_FIREBASE_AUTH_DOMAIN=jaindisha.firebaseapp.com
PUBLIC_FIREBASE_PROJECT_ID=jaindisha
PUBLIC_FIREBASE_APP_ID=
# The single admin allowed into /admin:
ALLOWED_ADMIN_EMAIL=
