<section>
  <div class="wrap">
    <div class="final rv">
      <div class="glow"></div>
      <h2 class="serif">Whenever you're ready,<br />I'm here.</h2>
      <p>There's no perfect time to start. There's just the next gentle step, and you can take it now.</p>
      <a href="#sessions" class="pill solid">Book your session <span class="ar">&rarr;</span></a>
    </div>
  </div>
</section>

<style>
  .final {
    position: relative;
    overflow: hidden;
    background: linear-gradient(150deg, var(--clay), var(--clay-dk));
    border-radius: 36px;
    text-align: center;
    color: #fff;
    padding: clamp(60px, 8vw, 110px) 28px;
  }
  .final h2 {
    color: #fff;
    font-size: clamp(34px, 4.6vw, 62px);
    margin-bottom: 16px;
    position: relative;
  }
  .final p {
    color: #f4e3d8;
    max-width: 44ch;
    margin: 0 auto 32px;
    font-size: 16px;
    position: relative;
  }
  .final .pill {
    position: relative;
  }
  .glow {
    position: absolute;
    width: 520px;
    height: 520px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(203, 184, 154, 0.5), transparent 65%);
    top: -200px;
    right: -120px;
  }
  .final .pill.solid {
    background: var(--cream2);
    color: var(--clay);
    box-shadow: 0 16px 36px -14px rgba(0, 0, 0, 0.4);
  }
</style>
