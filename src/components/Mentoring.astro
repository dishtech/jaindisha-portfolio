---
import { mentoring, social } from '../data/site';
---

<section id="mentoring">
  <div class="wrap">
    <div class="mentoring-band rv">
      <div class="mentoring-head">
        <div>
          <p class="kicker sage">For aspiring psychologists</p>
          <h2 class="serif heading">Charting your path in psychology?</h2>
        </div>
        <p class="intro">
          Beyond counselling, I mentor students and early-career psychologists — direction,
          entrance and interview prep, from someone a few steps ahead.
        </p>
      </div>

      <div class="mentoring-grid">
        {
          mentoring.map((o) => (
            <div class="moffer">
              <h3 class="serif">{o.name}</h3>
              <p class="mdesc">{o.desc}</p>
              <div class="mprice">{o.price}</div>
            </div>
          ))
        }
      </div>

      {/* M3: same custom booking flow as counselling, with a mentoring session type. Interim: Topmate. */}
      <a class="pill ghost cta" href={social.topmate} target="_blank" rel="noopener noreferrer">
        Explore mentoring <span class="ar">&rarr;</span>
      </a>
    </div>
  </div>
</section>

<style>
  .mentoring-band {
    background: linear-gradient(180deg, #efe4d2, #e7d8bf);
    border-radius: 36px;
    padding: clamp(44px, 6vw, 72px) clamp(28px, 5vw, 60px);
  }
  .mentoring-head {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 24px 40px;
    align-items: end;
  }
  .sage {
    color: var(--sage-dk);
  }
  .heading {
    font-size: clamp(26px, 3vw, 40px);
    margin-top: 10px;
  }
  .intro {
    font-size: 15px;
    color: var(--ink);
    opacity: 0.82;
    max-width: 42ch;
  }
  .mentoring-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 18px;
    margin-top: 36px;
  }
  .moffer {
    background: rgba(253, 248, 241, 0.7);
    border: 1px solid var(--line);
    border-radius: 16px;
    padding: 22px 22px 24px;
    transition: transform 0.35s cubic-bezier(0.2, 0.8, 0.2, 1), box-shadow 0.35s;
  }
  .moffer:hover {
    transform: translateY(-5px);
    box-shadow: 0 24px 48px -30px rgba(58, 46, 35, 0.4);
  }
  .moffer h3 {
    font-size: 20px;
  }
  .mdesc {
    font-size: 13.5px;
    margin: 8px 0 14px;
  }
  .mprice {
    font-family: var(--display);
    font-size: 23px;
    font-weight: 600;
    color: var(--clay-dk);
  }
  .cta {
    margin-top: 30px;
  }

  @media (max-width: 880px) {
    .mentoring-head {
      grid-template-columns: 1fr;
      align-items: start;
    }
    .mentoring-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
