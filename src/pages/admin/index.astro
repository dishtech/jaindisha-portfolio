---
export const prerender = false;
import Base from '../../layouts/Base.astro';
import { getAdmin } from '../../lib/requireAdmin';
import { listBookings } from '../../lib/bookings';
import { getOfferings } from '../../lib/offerings';
import { canSeeEarnings, canManageUsers, listAdmins, type Role } from '../../lib/roles';

const admin = await getAdmin(Astro.cookies);
if (!admin) return Astro.redirect('/admin/login');

const showEarnings = canSeeEarnings(admin.role);
const manageUsers = canManageUsers(admin.role);

let bookings: any[] = [];
let loadError = false;
try {
  bookings = await listBookings();
} catch (e) {
  console.error('admin listBookings failed', e);
  loadError = true;
}

const now = Date.now();
const paid = bookings.filter((b) => b.status === 'scheduled' || b.status === 'completed');
const upcoming = paid.filter((b) => b.slotStart && new Date(b.slotStart).getTime() > now).length;
const completed = bookings.filter((b) => b.status === 'completed').length;

let revenue = '';
if (showEarnings) {
  const d = new Date();
  const monthStart = new Date(d.getFullYear(), d.getMonth(), 1).getTime();
  const revenuePaise = paid
    .filter((b) => b.slotStart && new Date(b.slotStart).getTime() >= monthStart)
    .reduce((sum, b) => sum + (b.amountPaise || 0), 0);
  revenue = `₹${(revenuePaise / 100).toLocaleString('en-IN')}`;
}

let team: Awaited<ReturnType<typeof listAdmins>> = [];
if (manageUsers) {
  try {
    team = await listAdmins();
  } catch (e) {
    console.error('listAdmins failed', e);
  }
}

const fmt = new Intl.DateTimeFormat('en-IN', {
  day: 'numeric', month: 'short', hour: 'numeric', minute: '2-digit', hour12: true, timeZone: 'Asia/Kolkata',
});
const when = (iso?: string) => (iso ? fmt.format(new Date(iso)) : '-');
const offMap = new Map((await getOfferings()).map((o) => [o.id, o.name]));
const sessName = (id?: string) => offMap.get(id || '') || id || '-';
const rupees = (p?: number) => (p ? `₹${(p / 100).toLocaleString('en-IN')}` : '-');
const ROLE_LABEL: Record<Role, string> = { owner: 'Owner', 'super-admin': 'Super-admin', admin: 'Admin' };
const cols = showEarnings ? 5 : 4;
---

<Base title="Admin · Disha Jain" description="Bookings dashboard.">
  <main class="wrap admin">
    <div class="admin-head">
      <div>
        <p class="kicker">Admin · <span class="me-role">{ROLE_LABEL[admin.role]}</span></p>
        <h1 class="serif">Bookings</h1>
      </div>
      <div class="admin-actions">
        <a class="pill ghost" href="/">View site &nearr;</a>
        <a class="pill ghost" href="/admin/offerings">Sessions &amp; pricing</a>
        <a class="pill ghost" href="https://app.cal.com/availability" target="_blank" rel="noopener noreferrer">Availability &nearr;</a>
        <a class="pill ghost" href="https://app.cal.com/event-types" target="_blank" rel="noopener noreferrer">Event types &nearr;</a>
        <form method="POST" action="/api/session-logout"><button class="pill ghost" type="submit">Log out</button></form>
      </div>
    </div>

    {loadError && <p class="empty">Couldn't load bookings right now.</p>}

    <div class={`stats ${showEarnings ? '' : 'no-earn'}`}>
      <div class="stat"><span class="n">{bookings.length}</span><span class="l">Total</span></div>
      <div class="stat"><span class="n">{upcoming}</span><span class="l">Upcoming</span></div>
      <div class="stat"><span class="n">{completed}</span><span class="l">Completed</span></div>
      {showEarnings && <div class="stat"><span class="n">{revenue}</span><span class="l">This month</span></div>}
    </div>

    {bookings.length === 0 && !loadError ? (
      <p class="empty">No bookings yet.</p>
    ) : (
      <div class="table-wrap">
        <table class="bookings">
          <thead><tr><th>Client</th><th>Session</th><th>When</th><th>Status</th>{showEarnings && <th>Amount</th>}</tr></thead>
          <tbody>
            {bookings.map((b) => (
              <tr>
                <td>{b.clientName || '-'}<br /><span class="sub">{b.clientEmail || ''}</span></td>
                <td>{sessName(b.sessionType)}</td>
                <td>{when(b.slotStart)}</td>
                <td><span class={`badge s-${b.status}`}>{b.status}</span></td>
                {showEarnings && <td>{rupees(b.amountPaise)}</td>}
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    )}

    {manageUsers && (
      <section id="team-panel" class="team" data-me={admin.email} data-owner={admin.email}>
        <div class="team-head">
          <h2 class="serif">Team access</h2>
          <p class="team-sub">You're the owner, so only you can add or remove people. Everyone signs in with Google.</p>
        </div>

        <form id="team-add" class="team-add">
          <input name="email" type="email" required placeholder="teammate@gmail.com (their Google account)" autocomplete="off" />
          <select name="role" aria-label="Role">
            <option value="admin">Admin (no earnings)</option>
            <option value="super-admin">Super-admin (sees earnings)</option>
          </select>
          <button class="pill solid" type="submit">Add</button>
        </form>
        <p class="team-err" hidden></p>

        <div class="table-wrap">
          <table class="team-table">
            <thead><tr><th>Email</th><th>Role</th><th></th></tr></thead>
            <tbody id="team-rows">
              {team.map((a) => (
                <tr>
                  <td>{a.email}{(a.root || a.email === admin.email) && <span class="ttag">{a.root ? 'Owner' : 'You'}</span>}</td>
                  <td><span class={`rbadge r-${a.role}`}>{ROLE_LABEL[a.role]}</span></td>
                  <td>{!a.root && a.email !== admin.email && <button class="t-remove" data-email={a.email} type="button">Remove</button>}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      </section>
    )}
  </main>
</Base>

<script>
  const panel = document.getElementById('team-panel');
  if (panel) {
    const form = panel.querySelector('#team-add') as HTMLFormElement;
    const err = panel.querySelector('.team-err') as HTMLElement;

    async function post(payload: any) {
      const r = await fetch('/api/admin/team', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload),
      });
      const d = await r.json();
      if (!r.ok) throw new Error(d.error || 'Could not update the team.');
      return d;
    }

    function fail(ex: any) {
      err.textContent = ex?.message || 'Something went wrong.';
      err.hidden = false;
    }

    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      err.hidden = true;
      try {
        await post({ action: 'add', email: (form.email as any).value.trim(), role: (form.role as any).value });
        location.reload(); // server re-renders the list with correct (scoped) styling
      } catch (ex) {
        fail(ex);
      }
    });

    panel.querySelectorAll<HTMLElement>('.t-remove').forEach((b) =>
      b.addEventListener('click', async () => {
        const email = b.dataset.email;
        if (!email || !confirm(`Remove ${email}?`)) return;
        err.hidden = true;
        try {
          await post({ action: 'remove', email });
          location.reload();
        } catch (ex) {
          fail(ex);
        }
      })
    );
  }
</script>

<style>
  .admin { padding: clamp(36px, 6vw, 64px) 32px 80px; max-width: 1000px; }
  .admin-head { display: flex; justify-content: space-between; align-items: center; gap: 20px; margin-bottom: 30px; flex-wrap: wrap; }
  .admin-head h1 { font-size: clamp(30px, 4vw, 44px); margin-top: 4px; }
  .me-role { color: var(--clay); font-weight: 700; }
  .admin-actions { display: flex; align-items: center; gap: 10px; flex-wrap: wrap; }
  .admin-actions .pill { font-size: 13px; padding: 9px 16px; }
  .stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 16px; margin-bottom: 34px; }
  .stats.no-earn { grid-template-columns: repeat(3, 1fr); }
  .stat { background: var(--cream2); border: 1px solid var(--line); border-radius: 16px; padding: 20px; }
  .stat .n { display: block; font-family: var(--display); font-size: clamp(28px, 4vw, 40px); font-weight: 600; color: var(--clay); line-height: 1; }
  .stat .l { display: block; margin-top: 8px; font-size: 11px; letter-spacing: 0.12em; text-transform: uppercase; color: var(--sage-dk); font-weight: 700; }
  .empty { color: var(--body); font-size: 15px; padding: 16px 0; }
  .table-wrap { overflow-x: auto; }
  .bookings, .team-table { width: 100%; border-collapse: collapse; background: var(--cream2); border: 1px solid var(--line); border-radius: 14px; overflow: hidden; font-size: 14px; }
  .bookings th, .team-table th { text-align: left; font-family: var(--sans); font-size: 11px; letter-spacing: 0.06em; text-transform: uppercase; color: var(--clay-dk); font-weight: 700; padding: 12px 14px; background: rgba(168, 93, 66, 0.07); }
  .bookings td, .team-table td { padding: 12px 14px; border-top: 1px solid var(--line); vertical-align: top; color: var(--ink); }
  .bookings .sub { font-size: 12px; color: var(--body); }
  .badge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 100px; text-transform: capitalize; background: var(--cream); border: 1px solid var(--line); color: var(--body); }
  .badge.s-scheduled { background: #e3ecdf; color: var(--sage-dk); }
  .badge.s-completed { background: #dfe7ef; color: #3a5a76; }
  .badge.s-cancelled, .badge.s-failed { background: #f3ddd5; color: var(--clay-dk); }

  /* ---- team access ---- */
  .team { margin-top: 48px; }
  .team-head { margin-bottom: 16px; }
  .team-head h2 { font-size: clamp(22px, 3vw, 30px); color: var(--ink); }
  .team-sub { font-size: 14px; color: var(--body); margin-top: 4px; }
  .team-add { display: flex; gap: 10px; flex-wrap: wrap; margin-bottom: 8px; }
  .team-add input { flex: 1 1 260px; font-family: var(--sans); font-size: 14px; padding: 10px 14px; border: 1.5px solid var(--line); border-radius: 12px; background: #fff; color: var(--ink); }
  .team-add input:focus { outline: none; border-color: var(--clay); }
  .team-add select { font-family: var(--sans); font-size: 14px; padding: 10px 14px; border: 1.5px solid var(--line); border-radius: 12px; background: #fff; color: var(--ink); }
  .team-add .pill { padding: 10px 22px; }
  .team-err { color: var(--clay-dk); font-size: 13.5px; font-weight: 600; margin: 6px 0 12px; }
  .ttag { font-size: 10.5px; font-weight: 700; letter-spacing: 0.06em; text-transform: uppercase; color: var(--sage-dk); margin-left: 8px; }
  .rbadge { display: inline-block; font-size: 11px; font-weight: 700; padding: 3px 10px; border-radius: 100px; }
  .rbadge.r-owner { background: var(--clay); color: #fff; }
  .rbadge.r-super-admin { background: #dfe7ef; color: #3a5a76; }
  .rbadge.r-admin { background: #e3ecdf; color: var(--sage-dk); }
  .t-remove { background: none; border: 1px solid var(--line); color: var(--clay-dk); border-radius: 100px; padding: 5px 14px; font-family: var(--sans); font-size: 12.5px; font-weight: 600; cursor: pointer; transition: background 0.2s, color 0.2s, border-color 0.2s; }
  .t-remove:hover { background: var(--clay); color: #fff; border-color: var(--clay); }

  @media (max-width: 700px) {
    .stats, .stats.no-earn { grid-template-columns: repeat(2, 1fr); }
  }
</style>
