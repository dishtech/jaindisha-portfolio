---
import { about, images } from '../data/site';
---

<section id="about">
  <div class="wrap about">
    <div class="arch rv"><img src={images.about} alt="Disha Jain, PsyD trainee and counsellor" loading="lazy" /></div>
    <div class="rv">
      <p class="kicker">{about.kicker}</p>
      <h2>Warmth first.<br /><span class="em">Always.</span></h2>
      <p class="lead">{about.bio}</p>
      <div class="creds">
        {about.creds.map((c) => <span>{c}</span>)}
      </div>
    </div>
  </div>
</section>

<style>
  .about {
    display: grid;
    grid-template-columns: 0.92fr 1.08fr;
    gap: clamp(34px, 5vw, 76px);
    align-items: center;
  }
  .arch {
    position: relative;
    overflow: hidden;
    aspect-ratio: 1 / 1.12;
    border-radius: 22px 22px 200px 200px;
    box-shadow: 0 36px 70px -34px rgba(58, 46, 35, 0.4);
  }
  .arch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.02) sepia(0.06);
  }
  .about h2 {
    font-size: clamp(30px, 3.6vw, 50px);
    margin: 14px 0 18px;
  }
  .creds {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
    margin-top: 26px;
  }
  .creds span {
    font-size: 13px;
    font-weight: 600;
    color: var(--clay);
    background: var(--cream2);
    border: 1px solid var(--line);
    padding: 8px 15px;
    border-radius: 100px;
  }

  @media (max-width: 880px) {
    .about {
      grid-template-columns: 1fr;
    }
  }
</style>
