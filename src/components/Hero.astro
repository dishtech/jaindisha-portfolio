---
import { hero, practitioner, images } from '../data/site';
---

<header class="hero">
  <div class="wrap hero-grid">
    <div class="stg">
      <p class="kicker">{hero.kicker}</p>
      <h1>A gentle space to feel <span class="em">whole</span> again.</h1>
      <p class="hero-tag">{practitioner.tagline}</p>
      <p class="lead">{hero.lead}</p>
      <div class="ctas">
        <a href="#sessions" class="pill solid">Book a session <span class="ar">&rarr;</span></a>
        <a href="#work" class="pill ghost">How I work</a>
      </div>
    </div>

    <div class="hero-figure stg">
      <div class="b1"></div>
      <div class="arch"><img src={images.hero} alt="" loading="eager" /></div>
      <div class="b2">
        <div class="av"></div>
        <div>
          <small>{hero.badge.small}</small>
          <strong>{hero.badge.strong}</strong>
        </div>
      </div>
    </div>
  </div>
</header>

<style>
  .hero {
    padding: clamp(48px, 7vw, 96px) 0 clamp(60px, 8vw, 110px);
  }
  .hero-grid {
    display: grid;
    grid-template-columns: 1.04fr 0.96fr;
    gap: clamp(30px, 5vw, 72px);
    align-items: center;
  }
  .hero h1 {
    font-size: clamp(46px, 6.4vw, 94px);
    margin: 18px 0 16px;
  }
  .hero-tag {
    font-family: var(--display);
    font-style: italic;
    font-size: clamp(17px, 1.55vw, 21px);
    color: var(--sage-dk);
    margin-bottom: 18px;
  }
  .hero .lead {
    margin-bottom: 34px;
  }
  .hero .ctas {
    display: flex;
    gap: 14px;
    flex-wrap: wrap;
    align-items: center;
  }

  .hero-figure {
    position: relative;
  }
  .arch {
    position: relative;
    z-index: 2;
    aspect-ratio: 4 / 5;
    border-radius: 240px 240px 22px 22px;
    overflow: hidden;
    box-shadow: 0 40px 80px -30px rgba(58, 46, 35, 0.45);
  }
  .arch img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(1.02) sepia(0.06);
  }
  .b1 {
    position: absolute;
    z-index: 1;
    width: 64%;
    aspect-ratio: 1;
    border-radius: 50%;
    background: radial-gradient(circle at 35% 30%, var(--sage), var(--sage-dk));
    filter: blur(6px);
    opacity: 0.5;
    top: -6%;
    left: -12%;
  }
  .b2 {
    position: absolute;
    z-index: 3;
    bottom: 8%;
    left: -9%;
    background: var(--cream2);
    border: 1px solid var(--line);
    border-radius: 18px;
    padding: 16px 18px;
    box-shadow: 0 20px 40px -18px rgba(58, 46, 35, 0.32);
    display: flex;
    gap: 12px;
    align-items: center;
  }
  .b2 .av {
    width: 42px;
    height: 42px;
    border-radius: 50%;
    background: linear-gradient(135deg, var(--clay), var(--sand));
  }
  .b2 small {
    display: block;
    font-size: 11.5px;
    color: var(--sage-dk);
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .b2 strong {
    font-family: var(--display);
    font-size: 19px;
    color: var(--ink);
    font-weight: 600;
  }

  @media (max-width: 880px) {
    .hero-grid {
      grid-template-columns: 1fr;
    }
    .hero-figure {
      order: -1;
      max-width: 420px;
      margin: 0 auto;
    }
  }
</style>
