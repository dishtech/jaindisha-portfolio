---
import { faqs } from '../data/site';
---

<section id="faq">
  <div class="wrap">
    <div class="center rv">
      <p class="kicker stamp">Gentle answers</p>
      <h2 class="h-sec">Things people often wonder.</h2>
    </div>
    {/* TODO: confirm all FAQ wording with Disha before M6 launch (confidentiality limits, online-only, trainee scope). */}
    <div class="faq rv">
      {
        faqs.map((f, i) => (
          <details open={i === 0}>
            <summary>{f.q} <span class="ic">+</span></summary>
            <p>{f.a}</p>
          </details>
        ))
      }
    </div>
  </div>
</section>

<style>
  .faq {
    max-width: 760px;
    margin: 46px auto 0;
  }
  details {
    border-top: 1px solid var(--line);
  }
  details:last-child {
    border-bottom: 1px solid var(--line);
  }
  summary {
    list-style: none;
    cursor: pointer;
    padding: 22px 4px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
    font-size: 18px;
    font-weight: 600;
    color: var(--ink);
  }
  summary::-webkit-details-marker {
    display: none;
  }
  summary .ic {
    width: 30px;
    height: 30px;
    flex: 0 0 auto;
    border-radius: 50%;
    border: 1.5px solid var(--clay);
    color: var(--clay);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.3s, background 0.3s, color 0.3s;
    font-size: 18px;
  }
  details[open] summary .ic {
    transform: rotate(45deg);
    background: var(--clay);
    color: #fff;
  }
  details p {
    padding: 0 4px 24px;
    font-size: 15px;
    max-width: 62ch;
  }
</style>
