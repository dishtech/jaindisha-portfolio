---
import { mentoringAbout } from '../data/site';
---

<section id="mentoring">
  <div class="wrap">
    <div class="mentoring-band rv">
      <div class="m-copy">
        <p class="kicker sage">For aspiring psychologists</p>
        <h2 class="serif heading">Charting your path in psychology?</h2>
        <p class="intro">
          I mentor psychology students and early-career psychologists: direction, guidance, and
          interview prep for entrances and the years after.
        </p>
        <a class="pill ghost cta" href="/mentoring">Explore mentoring <span class="ar">&rarr;</span></a>
      </div>

      <div class="m-cred">
        <div class="air">
          <span class="air-num serif">{mentoringAbout.air.num}</span>
          <span class="air-label">{mentoringAbout.air.label}</span>
        </div>
        <p class="cred-note">{mentoringAbout.airNote}</p>
      </div>
    </div>
  </div>
</section>

<style>
  .mentoring-band {
    background: linear-gradient(180deg, #efe4d2, #e7d8bf);
    border-radius: 36px;
    padding: clamp(44px, 6vw, 72px) clamp(28px, 5vw, 60px);
    display: grid;
    grid-template-columns: 1.15fr 0.85fr;
    gap: clamp(32px, 5vw, 64px);
    align-items: center;
  }
  .sage {
    color: var(--sage-dk);
  }
  .heading {
    font-size: clamp(28px, 3.4vw, 44px);
    margin: 10px 0 14px;
  }
  .intro {
    font-size: 15.5px;
    color: var(--ink);
    opacity: 0.85;
    max-width: 44ch;
    margin-bottom: 26px;
  }
  .cta {
    /* ghost pill on the sand band, stays subordinate to the clay counselling CTAs */
  }

  .m-cred {
    border-left: 2px solid rgba(168, 93, 66, 0.25);
    padding-left: clamp(24px, 4vw, 40px);
  }
  .air {
    display: flex;
    flex-direction: column;
    margin-bottom: 14px;
  }
  .air-num {
    font-size: clamp(46px, 6vw, 68px);
    font-weight: 600;
    color: var(--clay);
    line-height: 0.95;
  }
  .air-label {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--sage-dk);
    font-weight: 700;
    margin-top: 8px;
  }
  .cred-note {
    font-size: 14.5px;
    color: var(--ink);
    opacity: 0.82;
    max-width: 34ch;
    font-style: italic;
    font-family: var(--display);
  }

  @media (max-width: 880px) {
    .mentoring-band {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    .m-cred {
      border-left: none;
      border-top: 2px solid rgba(168, 93, 66, 0.25);
      padding-left: 0;
      padding-top: 28px;
    }
  }
</style>
