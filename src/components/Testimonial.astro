---
import { testimonial } from '../data/site';
---

<section>
  <div class="wrap">
    <div class="quote-sec rv">
      <span class="mark">&ldquo;</span>
      <blockquote>{testimonial.quote}</blockquote>
      <cite>{testimonial.cite}</cite>
    </div>
  </div>
</section>

<style>
  .quote-sec {
    position: relative;
    background: linear-gradient(160deg, var(--sage), var(--sage-dk));
    border-radius: 36px;
    overflow: hidden;
    color: #fff;
    text-align: center;
    padding: clamp(60px, 8vw, 108px) 28px;
  }
  .mark {
    font-family: var(--display);
    font-size: 200px;
    line-height: 0.7;
    color: rgba(255, 255, 255, 0.16);
    position: absolute;
    top: 24px;
    left: 50%;
    transform: translateX(-50%);
  }
  blockquote {
    font-family: var(--display);
    font-size: clamp(24px, 3vw, 38px);
    font-style: italic;
    font-weight: 500;
    line-height: 1.34;
    color: #fff;
    max-width: 28ch;
    margin: 0 auto;
    position: relative;
  }
  cite {
    display: block;
    margin-top: 26px;
    font-family: var(--sans);
    font-style: normal;
    font-size: 13px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #dce7d8;
  }
</style>
